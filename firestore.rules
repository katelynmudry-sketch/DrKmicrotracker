rules_version = '2';

// Source of truth for Firestore access control. Update this file in the same
// change as any new client-side query — see CLAUDE.md's architecture rules.
//
// Server functions (src/lib/*.functions.ts) use the Admin SDK, which bypasses
// these rules entirely. These rules only govern direct browser access via the
// client Firebase SDK.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDoctor() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    // Role is never client-writable — profiles are created and promoted only
    // by the ensureRole / promoteToDoctor server functions (Admin SDK).
    // Every other user preference (detailLevel, focus nutrients,
    // preferredCuisine) also goes through a users.functions.ts server
    // function, not a direct client write — see that file.
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isDoctor());
      allow list: if isDoctor();
      allow create, update, delete: if false;
    }

    // Meals: owner may create and read their own; doctor may read all and
    // edit only doctorNotes. status/analysis/rubricIds are entirely
    // server-owned — set only by the analyzeMeal / updateMealAnalysis server
    // functions (Admin SDK, bypasses these rules). The client creates a meal
    // as 'pending' and never writes status again; a stuck or failed meal is
    // recovered by re-invoking analyzeMeal (Retry / Re-analyze), not by a
    // client-side Firestore write.
    match /meals/{mealId} {
      allow get: if isSignedIn() &&
        (resource.data.patientId == request.auth.uid || isDoctor());
      allow list: if isDoctor() ||
        (isSignedIn() && resource.data.patientId == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.patientId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.analysis == null;

      allow update: if isDoctor() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['doctorNotes']);

      allow delete: if false;
    }

    // Rubrics: doctor-only, end to end.
    match /rubrics/{rubricId} {
      allow get, list: if isDoctor();
      allow create: if isDoctor() && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isDoctor() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive']);
      allow delete: if isDoctor();
    }

    // Pantry items and the grocery list: patient-owned end to end, no doctor
    // access (post-demo milestone #1, docs/PLAN.md) — unlike meals, there's no
    // server-owned lifecycle field here, so the client can update/delete its
    // own docs directly.
    match /pantry_items/{itemId} {
      allow get, list: if isSignedIn() && resource.data.patientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.patientId == request.auth.uid;
    }

    match /grocery_list_items/{itemId} {
      allow get, list: if isSignedIn() && resource.data.patientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.patientId == request.auth.uid;
    }
  }
}
