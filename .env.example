# Firebase web app config (client-side, safe to expose) — from Firebase console
# Project settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only secret) — from Firebase console
# Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Anthropic Claude API key — from console.anthropic.com
ANTHROPIC_API_KEY=

# Comma-separated emails that get the doctor role on first sign-in
DOCTOR_EMAILS=

# Set to "true" to enable the doctor's Seed/Clear demo data buttons (see
# docs/DEMO.md). Leave unset in production.
DEMO_MODE=

# Master kill switch for the doctor/admin side (patient list, review/
# annotation, rubric upload, doctor-role granting). The doctor side is
# intentionally disabled for the current people-testing round — see
# docs/OWNER-TODO.md. Set BOTH to "true" together to re-enable it, and only
# after HIPAA compliance work is done. Leave both unset/false otherwise.
DOCTOR_FEATURE_ENABLED=
VITE_DOCTOR_FEATURE_ENABLED=
